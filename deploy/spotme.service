[Unit]
Description=SpotMe workout tracker server
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/spotme
ExecStart=%h/spotme/.venv/bin/uvicorn server.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5
Environment=PATH=%h/.local/bin:/usr/bin

[Install]
WantedBy=default.target
